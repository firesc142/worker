{
  "name": "paperfly",
  "version": "1.0.0",
  "description": "Paperfly",
  "main": "server/server.js",
  "bin": {
    "paperfly": "./bin/cli.js"
  },
  "scripts": {
    "postinstall": "node bin/install.js",
    "preuninstall": "node bin/uninstall.js",
    "start": "node server/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32"
  ],
  "keywords": [
    "paperfly",
    "remote-desktop",
    "screen-share",
    "localtunnel",
    "remote-control"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^6.0.1",
    "cloudflared": "^0.7.1",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "localtunnel": "^2.0.2",
    "multer": "^2.0.0",
    "node-screenshots": "^0.2.8",
    "screenshot-desktop": "^1.15.0",
    "socket.io": "^4.7.2",
    "systray2": "^2.1.4",
    "wake_on_lan": "^1.0.0"
  },
  "optionalDependencies": {
    "koffi": "^2.9.0",
    "sharp": "^0.33.5"
  },
  "allowScripts": {
    "koffi@2.16.2": true,
    "cloudflared@0.7.1": true
  }
}
