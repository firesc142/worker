{
  "name": "paperfly",
  "version": "1.0.0",
  "description": "Paperfly",
  "main": "server/server.js",
  "bin": {
    "paperfly": "./bin/cli.js"
  },
  "scripts": {
    "prepare": "node -e \"\"",
    "postinstall": "node -e \"try{require('./bin/install.js')}catch(e){console.log('Setup skipped:',e.message)}\"",
    "preuninstall": "node bin/uninstall.js",
    "start": "node server/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32"
  ],
  "keywords": [
    "paperfly",
    "remote-desktop",
    "screen-share",
    "localtunnel",
    "remote-control"
  ],
  "files": [
    "bin/",
    "server/",
    "public/",
    "package.json"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^6.0.1",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "localtunnel": "^2.0.2",
    "multer": "^2.0.0",
    "screenshot-desktop": "^1.15.0",
    "socket.io": "^4.7.2",
    "wake_on_lan": "^1.0.0"
  },
  "optionalDependencies": {
    "cloudflared": "^0.7.1",
    "koffi": "^2.9.0",
    "node-screenshots": "^0.2.8",
    "sharp": "^0.33.5",
    "systray2": "^2.1.4"
  },
  "allowScripts": {
    "koffi@2.16.2": true,
    "cloudflared@0.7.1": true
  }
}
